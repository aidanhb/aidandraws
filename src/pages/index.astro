---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ArchiveBanner from '../components/ArchiveBanner.astro';
import Portfolio from '../components/Portfolio.astro';
import About from '../components/About.astro';
import Books from '../components/Books.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />

  <main>
    <Hero />

    <ArchiveBanner />

    <section id="portfolio" class="py-16 scroll-mt-20">
      <Portfolio />
    </section>

    <section id="books" class="py-16 scroll-mt-20">
      <Books />
    </section>

    <section id="about-me" class="py-16 scroll-mt-20">
      <About />
    </section>
  </main>

  <Footer />
</BaseLayout>
