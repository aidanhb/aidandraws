---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Portfolio from '../components/Portfolio.astro';
import About from '../components/About.astro';
import Books from '../components/Books.astro';
import Footer from '../components/Footer.astro';
import Awards from '../components/Awards.astro';
import { getHeroSlides, HERO_SIZES } from '../lib/hero-slides';

const slides = await getHeroSlides();
const first = slides[0];
const heroPreload = first
  ? { srcSetAvif: first.srcSetAvif, srcSetWebp: first.srcSetWebp, sizes: HERO_SIZES }
  : undefined;
---

<BaseLayout heroPreload={heroPreload}>
  <Nav />

  <main>
    <Hero slides={slides} />

    <section class="text-center text-xl max-w-300 mx-auto px-6 py-8 mt-4 border border-text-title/50 rounded-full">
      <p class="text-3xl font-heading text-text-title uppercase tracking-widest mb-2">Hi! I'm Aidan Holloway-Bidwell</p>
      <p class="text-text-title" >Do you need artwork for your project? I do commissions, let's work together.</p>
      <p class="text-text-secondary">
        Send me an email at{' '}
        <a href="mailto:aidan@aidandraws.com" class=" underline hover:no-underline">aidan@aidandraws.com</a>
      </p>
    </section>

    <Awards />

    <section id="portfolio" class="py-16 scroll-mt-20">
      <Portfolio />
    </section>

    <section id="books" class="py-16 scroll-mt-20">
      <Books />
    </section>

    <section id="about-me" class="py-16 scroll-mt-20">
      <About />
    </section>
  </main>

  <Footer />
</BaseLayout>
