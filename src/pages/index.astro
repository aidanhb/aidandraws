---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Portfolio from '../components/Portfolio.astro';
import About from '../components/About.astro';
import Books from '../components/Books.astro';
import Footer from '../components/Footer.astro';
import Intro from '../components/Intro.astro';
import { getHeroSlides, HERO_SIZES } from '../lib/hero-slides';

const slides = await getHeroSlides();
const first = slides[0];
const heroPreload = first
  ? { srcSetAvif: first.srcSetAvif, srcSetWebp: first.srcSetWebp, sizes: HERO_SIZES }
  : undefined;
---

<BaseLayout heroPreload={heroPreload}>
  <Nav />

  <main>
    <Hero slides={slides} />

    <Intro />

    <section id="portfolio" class="py-16 scroll-mt-20">
      <Portfolio />
    </section>

    <section id="books" class="py-16 scroll-mt-20">
      <Books />
    </section>

    <section id="about-me" class="py-16 scroll-mt-20">
      <About />
    </section>
  </main>

  <Footer />
</BaseLayout>
