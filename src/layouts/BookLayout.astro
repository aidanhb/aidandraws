---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Flipbook from '../components/react/Flipbook';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { loadFlipbook } from '../lib/load-flipbook';

interface Props {
  book: CollectionEntry<'books'>;
}

const { book } = Astro.props;
const { title, description, cover, alt, year, numPages } = book.data;

const pages = await loadFlipbook(book.id);
---

<BaseLayout title={`${title} | Aidan Holloway-Bidwell`} description={description}>
  <Nav />

  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <article>

      <!-- Header: cover + metadata -->
      <div class="flex flex-col sm:flex-row gap-8 items-start mb-12">
        <div class="hidden sm:block flex-none w-48">
          <Image
            src={cover}
            alt={alt}
            class="w-full h-auto rounded shadow-md ring-1 ring-text/20"
          />
        </div>
        <div class="flex-1 pt-1">
          <h1 class="text-h4 md:text-h2 font-heading text-text-title uppercase mb-2">{title}</h1>
          {(year || numPages) && (
            <p class="text-p3 font-body text-text-secondary mb-4">
              {[year, numPages ? `${numPages} pages` : undefined].filter(Boolean).join(' · ')}
            </p>
          )}
          <div class="text-p2 font-body text-text leading-relaxed space-y-4">
            <slot />
          </div>
        </div>
      </div>

      <!-- Flipbook -->
      {pages.length > 0 && (
        <div class="mt-8">
          <Flipbook pages={pages} alt={`Flipbook of ${title}`} client:only="react" />
          {/* SSR skeleton — reserves space while the JS bundle loads and React hydrates.
              Hidden by the :not(:empty) selector below once astro-island has React children. */}
          <div
            class="flipbook-ssr-skeleton w-full rounded bg-text/10 aspect-[3/4] md:aspect-[3/2] animate-pulse"
            aria-hidden="true"
          />
        </div>
      )}

    </article>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* Once react-pageflip has hydrated and added children to its astro-island, hide the SSR skeleton. */
  astro-island:not(:empty) + .flipbook-ssr-skeleton {
    display: none;
  }
</style>
