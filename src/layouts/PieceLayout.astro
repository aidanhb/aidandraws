---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  piece: CollectionEntry<'portfolio'>;
}

const { piece } = Astro.props;
const { title, description, heroImage, alt, medium, dimensions } = piece.data;
---

<BaseLayout title={`${title} | Aidan Holloway-Bidwell`} description={description}>
  <Nav />

  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <article>
      <h1 class="text-h1 font-heading text-text-title uppercase mb-2">{title}</h1>

      {(medium || dimensions) && (
        <p class="text-p3 font-body text-text/50 mb-8">
          {[medium, dimensions].filter(Boolean).join(' — ')}
        </p>
      )}

      <button type="button" data-lightbox class="block w-full mb-10 cursor-zoom-in" aria-label="View full size">
        <Image
          src={heroImage}
          alt={alt}
          widths={[800, 1200]}
          sizes="(max-width: 1200px) 100vw, 1200px"
          class="w-full object-contain pointer-events-none"
        />
      </button>

      <p class="text-p1 font-body text-text mb-10">{description}</p>

      <div class="text-p2 font-body text-text space-y-4 leading-relaxed [&>p]:max-w-2xl [&>ul]:max-w-2xl [&>ol]:max-w-2xl [&>blockquote]:max-w-2xl">
        <slot />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
