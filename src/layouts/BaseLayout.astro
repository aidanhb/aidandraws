---
import '../styles/global.css';
import ThemePicker from '../components/react/ThemePicker';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import logoRaw from '../assets/svg/logo_simple.svg?raw';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Aidan Holloway-Bidwell | Illustrator',
  description = 'Fantasy illustration and worldbuilding by Aidan Holloway-Bidwell.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);

// Process portrait images for ThemePicker — originals are ~900px / 150KB each. Largest
// display is the floating trigger at w-24 (96px), so 200px is plenty even at 2x DPR.
// Explicit width + format prevent getImage URL collisions across parallel calls.
const portraitGlob = import.meta.glob<ImageMetadata>('../assets/themes/*.webp', {
  eager: true,
  import: 'default',
});
const portraits: Record<string, string> = {};
await Promise.all(
  Object.entries(portraitGlob).map(async ([path, img]) => {
    const id = path.split('/').pop()?.replace('.webp', '') ?? '';
    if (!id) return;
    const optimized = await getImage({ src: img, width: 200, format: 'webp', quality: 80 });
    portraits[id] = optimized.src;
  }),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- No static favicon link — the script below provides the theme-tinted favicon on every load,
         and a static link can cause Chrome to cache it for this URL and ignore later replacements. -->

    <!-- No-flash theme restore — must run synchronously before paint -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('aidandraws-theme');
          document.documentElement.setAttribute('data-theme', saved || 'wizard');
        } catch {
          document.documentElement.setAttribute('data-theme', 'wizard');
        }
      })();
    </script>

    <!-- Theme-tinted favicon — rasterizes the logo SVG to a PNG via canvas with the current theme's
         text color. PNG data URLs are universally supported as favicons, and each color produces a
         distinct data URL, which sidesteps browsers' favicon caches. -->
    <script is:inline define:vars={{ logoRaw }}>
      (function () {
        const FAVICON_SIZE = 64;
        function escapeColor(c) {
          return c.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        }
        function update() {
          const raw = getComputedStyle(document.documentElement).getPropertyValue('--color-text').trim();
          if (!raw) {
            // CSS variable not yet resolved (e.g., dev-mode JS-injected styles haven't applied) — retry next frame.
            requestAnimationFrame(update);
            return;
          }
          // Tailwind stores theme colors as bare RGB triplets (e.g. "255 136 184") so they can be
          // composed with alpha via rgb(var(--color) / <alpha>). Canvas fillStyle and SVG fill won't
          // accept the bare form — wrap in legacy comma rgb(R, G, B).
          const color = /^[\d\s.]+$/.test(raw) ? 'rgb(' + raw.split(/\s+/).join(', ') + ')' : raw;
          const safe = escapeColor(color);
          // Inject explicit width/height (Image() needs intrinsic dimensions to rasterize reliably).
          // Also apply fill directly to every <path> — the Image→Canvas SVG rasterizer doesn't
          // reliably inherit fill from the root <svg>, so per-path fill is the only safe option.
          const svg = logoRaw
            .replace(/^<\?xml[^>]*\?>\s*/, '')
            .replace(/<svg\b([^>]*)>/, function (_, attrs) {
              const stripped = attrs
                .replace(/\s+fill="[^"]*"/, '')
                .replace(/\s+width="[^"]*"/, '')
                .replace(/\s+height="[^"]*"/, '');
              return '<svg' + stripped + ' width="' + FAVICON_SIZE + '" height="' + FAVICON_SIZE + '">';
            })
            .replace(/<path\b([^>]*?)\s*\/?>/g, function (_, attrs) {
              const stripped = attrs.replace(/\s+fill="[^"]*"/, '');
              return '<path' + stripped + ' fill="' + safe + '"/>';
            });
          const img = new Image();
          img.onload = function () {
            const canvas = document.createElement('canvas');
            canvas.width = FAVICON_SIZE;
            canvas.height = FAVICON_SIZE;
            canvas.getContext('2d').drawImage(img, 0, 0, FAVICON_SIZE, FAVICON_SIZE);
            const href = canvas.toDataURL('image/png');
            document.querySelectorAll('link[rel*="icon"]').forEach(function (l) { l.remove(); });
            const link = document.createElement('link');
            link.rel = 'icon';
            link.type = 'image/png';
            link.href = href;
            document.head.appendChild(link);
          };
          img.src = 'data:image/svg+xml,' + encodeURIComponent(svg);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', update);
        } else {
          update();
        }
        new MutationObserver(update).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['data-theme'],
        });
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;700&family=Space+Grotesk:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg text-text font-body min-h-screen">
    <slot />
    <ThemePicker portraits={portraits} client:idle />
  </body>
</html>
