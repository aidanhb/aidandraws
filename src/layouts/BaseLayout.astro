---
import '../styles/global.css';
import ThemePicker from '../components/react/ThemePicker';
import LightboxPortal from '../components/react/LightboxPortal';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  heroPreload?: {
    srcSetAvif: string;
    srcSetWebp: string;
    sizes: string;
  };
}

const {
  title = 'Aidan Holloway-Bidwell | Illustrator',
  description = 'Fantasy illustration and worldbuilding by Aidan Holloway-Bidwell.',
  ogImage = '/og-default.png',
  heroPreload,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);

// Process portrait images for ThemePicker — originals are ~900px / 150KB each. Largest
// display is the floating trigger at w-24 (96px), so 200px is plenty even at 2x DPR.
// Explicit width + format prevent getImage URL collisions across parallel calls.
const portraitGlob = import.meta.glob<ImageMetadata>('../assets/themes/*.webp', {
  eager: true,
  import: 'default',
});
const portraits: Record<string, string> = {};
await Promise.all(
  Object.entries(portraitGlob).map(async ([path, img]) => {
    const id = path.split('/').pop()?.replace('.webp', '') ?? '';
    if (!id) return;
    const optimized = await getImage({ src: img, width: 200, format: 'webp', quality: 80 });
    portraits[id] = optimized.src;
  }),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- No static favicon link — the script below provides the theme-tinted favicon on every load,
         and a static link can cause Chrome to cache it for this URL and ignore later replacements. -->

    <!-- No-flash theme restore — must run synchronously before paint -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('aidandraws-theme');
          document.documentElement.setAttribute('data-theme', saved || 'wizard');
        } catch {
          document.documentElement.setAttribute('data-theme', 'wizard');
        }
      })();
    </script>

    <!-- Theme-tinted favicon — bundled by Astro/Vite from src/lib/themed-favicon.ts. -->
    <script>
      import logoRaw from '../assets/svg/logo_simple.svg?raw';
      import { installThemedFavicon } from '../lib/themed-favicon';
      installThemedFavicon(logoRaw);
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      heroPreload && (
        <link
          rel="preload"
          as="image"
          type="image/avif"
          imagesrcset={heroPreload.srcSetAvif}
          imagesizes={heroPreload.sizes}
          fetchpriority="high"
        />
      )
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;700&family=Space+Grotesk:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg text-text font-body min-h-screen">
    <slot />
    <ThemePicker portraits={portraits} client:idle />
    <LightboxPortal client:idle />

    <!-- Delegate lightbox triggers: any [data-lightbox] button fires lightbox:open with
         the resolved src from its child <img> (currentSrc picks the right srcset variant). -->
    <script is:inline>
      document.addEventListener('click', function (e) {
        const trigger = e.target.closest('[data-lightbox]');
        if (!trigger) return;
        const img = trigger.querySelector('img');
        if (!img) return;
        window.dispatchEvent(new CustomEvent('lightbox:open', {
          detail: { src: img.currentSrc || img.src, alt: img.alt }
        }));
      });
    </script>
  </body>
</html>
