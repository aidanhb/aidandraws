---
import { Image } from 'astro:assets';
import bannerImage from '../assets/books/archive/banner.webp';
import soldierImage from '../assets/books/archive/soldier.webp';
import purpleHelmetImage from '../assets/books/archive/purple_helmet.webp';
import logoRaw from '../assets/svg/archive.svg?raw';

// Force white fill on the wordmark — the source SVG has no fill set so defaults to black.
const logoSvg = logoRaw.replace(/<svg\b([^>]*)>/, (_, attrs) => {
  const stripped = (attrs as string).replace(/\s+fill="[^"]*"/, '');
  return `<svg${stripped} fill="white">`;
});
---

<section aria-label="ArcHive — featured worldbuilding project" class="w-full mt-2 mb-12">
  <div class="relative w-full overflow-hidden aspect-[3/1] md:aspect-[6/1]">
    <Image
      src={bannerImage}
      alt=""
      width={2400}
      class="absolute inset-0 w-full h-full object-cover block"
      loading="lazy"
    />
    <div class="absolute inset-0 flex items-center justify-center gap-4 md:gap-8 px-4 md:px-8 text-white">
      <Image
        src={soldierImage}
        alt=""
        width={400}
        class="hidden md:block h-[90%] w-auto object-contain"
        loading="lazy"
      />
      <div class="flex flex-col items-center gap-2 min-w-0">
        <span
          aria-hidden="true"
          class="block h-10 md:h-14 [&>svg]:h-full [&>svg]:w-auto drop-shadow-lg"
          set:html={logoSvg}
        />
        <p class="text-center text-p3 font-body drop-shadow">
          Check out my new worldbuilding project, <a
            href="/books/archive"
            class="underline hover:no-underline text-white italic"
          >ArcHive</a>.
        </p>
      </div>
      <Image
        src={purpleHelmetImage}
        alt=""
        width={400}
        class="hidden md:block h-3/4 w-auto object-contain translate-x-10"
        loading="lazy"
      />
    </div>
  </div>
</section>
