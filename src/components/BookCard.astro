---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  book: CollectionEntry<'books'>;
}

const { book } = Astro.props;
const { title, description, cover, alt, year, numPages } = book.data;
---

<a
  href={`/books/${book.id}`}
  class="flex flex-col sm:flex-row gap-6 items-start group no-underline hover:no-underline"
>
  <div class="w-full sm:flex-none sm:w-64 overflow-hidden rounded shadow-md ring-1 ring-text/20 transition-transform duration-300 group-hover:scale-105">
    <Image
      src={cover}
      alt={alt}
      class="w-full h-auto object-contain"
    />
  </div>
  <div class="flex-1 min-w-0 sm:pt-1">
    <p class="font-heading text-text-secondary uppercase tracking-wider text-p1 leading-tight mb-2">{title}</p>
    {(year || numPages) && (
      <p class="font-body text-text-secondary text-p3 mt-3">
        {[year, numPages ? `${numPages} pages` : undefined].filter(Boolean).join(' · ')}
      </p>
    )}
    <p class="font-body text-text text-p2 leading-relaxed">{description}</p>
  </div>
</a>
