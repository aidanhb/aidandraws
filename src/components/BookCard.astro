---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  cover: ImageMetadata;
  alt: string;
  href?: string;
  year?: number;
  numPages?: number;
}

const { title, description, cover, alt, href, year, numPages } = Astro.props;

const Tag = href ? 'a' : 'div';
const tagProps = href ? { href, class: 'no-underline hover:no-underline' } : {};
---

<Tag
  {...tagProps}
  class:list={[
    'flex gap-6 items-start group',
    href && 'no-underline hover:no-underline',
  ]}
>
  <div class="flex-none w-64 overflow-hidden rounded shadow-md ring-1 ring-text/20 transition-transform duration-300 group-hover:scale-[1.03]">
    <Image
      src={cover}
      alt={alt}
      class="w-full h-auto object-contain"
    />
  </div>
  <div class="flex-1 min-w-0 pt-1">
    <p class="font-heading text-text-link uppercase tracking-wider text-p1 leading-tight mb-2">{title}</p>
    {(year || numPages) && (
      <p class="font-body text-text-secondary text-p3 mt-3">
        {[year, numPages ? `${numPages} pages` : undefined].filter(Boolean).join(' · ')}
      </p>
    )}
    <p class="font-body text-text text-p2 leading-relaxed">{description}</p>
  </div>
</Tag>
