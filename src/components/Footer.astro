<footer class="border-t border-white/10 py-10 mt-16">
  <div
    class="max-w-[1200px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4"
  >
    <p class="text-p3 font-body text-white/50">
      &copy; {new Date().getFullYear()} Aidan Holloway-Bidwell. All rights reserved.
    </p>

    <div class="flex items-center gap-6">
      <a
        href="mailto:aidan@aidandraws.com"
        class="text-p3 font-body text-text-link hover:text-white transition-colors no-underline hover:underline"
      >
        aidan@aidandraws.com
      </a>
      <a
        href="https://www.instagram.com/aidan_thats_me/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-text-link hover:text-white transition-colors flex items-center"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"></circle>
        </svg>
      </a>
    </div>
  </div>
</footer>
