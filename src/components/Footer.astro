---
import SocialIcon from './SocialIcon.astro';
---

<footer class="border-t border-white/10 py-10 mt-16">
  <div
    class="max-w-[1200px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4"
  >
    <p class="text-p3 font-body text-text/50">
      &copy; {new Date().getFullYear()} Aidan Holloway-Bidwell. All rights reserved.
    </p>

    <div class="flex items-center gap-6">
      <a
        href="mailto:aidan@aidandraws.com"
        class="text-p3 font-body text-text-link hover:text-text transition-colors no-underline hover:underline"
      >
        aidan@aidandraws.com
      </a>
      <SocialIcon platform="instagram" size={18} />
    </div>
  </div>
</footer>
