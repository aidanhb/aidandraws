---
interface Props {
  title: string;
  subtitle: string;
  href?: string;
  logoHtml: string;
  logoHeight?: string;
}

const { title, subtitle, href, logoHtml, logoHeight = 'h-28' } = Astro.props;
---

<div class="flex flex-col items-center gap-3 text-text-secondary">
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="text-text-secondary no-underline"
  >
    <div class="text-center">
      <p class="font-heading sm:text-xl lg:text-2xl uppercase tracking-widest">{title}</p>
      <p class="font-body text-sm uppercase tracking-widest -mt-1">{subtitle}</p>
    </div>
  </a>
  <div class={`${logoHeight} [&>svg]:h-full [&>svg]:w-auto`} set:html={logoHtml} />
</div>
