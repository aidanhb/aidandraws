---
import Awards from './Awards.astro';
import Testimonials from './Testimonials.astro';
---

<section id="intro" class="max-w-300 mx-auto px-8 py-10 mt-4">
  <div class="text-center mb-6">
    <div class="max-w-240 mx-auto">
      <p class="text-4xl font-heading text-text-title uppercase tracking-widest mb-2">Hi! I'm Aidan Holloway-Bidwell</p>
    </div>
    <div class="mb-4">
      <Awards />
    </div>
    <p class="text-2xl text-text-title mb-4">I paint fantasy and sci-fi worlds, and I take commissions.</p>
    <a href="mailto:aidan@aidandraws.com" target="_blank" rel="noopener noreferrer" class="inline-block bg-text-link text-bg font-heading font-bold uppercase tracking-widest px-6 pb-2.5 pt-3.5 rounded-full no-underline hover:opacity-70 transition-opacity mt-2">
      Send me an email
    </a>
  </div>

  <hr class="border-text-title/20 mb-6" />

  <p class="font-heading text-sm uppercase tracking-widest text-text-secondary text-center mb-6">What Clients Say</p>
  <Testimonials />
</section>
