---
import { getCollection } from 'astro:content';
import PortfolioCard from './PortfolioCard.astro';

const allPieces = await getCollection('portfolio');
const sorted = allPieces.sort((a, b) => {
  const aOrder = a.data.order ?? Infinity;
  const bOrder = b.data.order ?? Infinity;
  if (aOrder !== bOrder) return aOrder - bOrder;
  return a.data.title.localeCompare(b.data.title);
});
---

<div class="max-w-[1200px] mx-auto px-6">
  <h2 class="text-h2 font-heading text-text-title uppercase mb-4">Portfolio</h2>
    <div class="py-16 border-t border-text/10">
      <div class="space-y-4">
        <p class="text-p1 font-body text-text-secondary leading-relaxed">
          I aim to make fantasy feel as tangible as reality.
        </p>
        <p class="text-p2 font-body text-text leading-relaxed">
          Each painting is a puzzle to solve. The client provides a number of oddly-shaped pieces:
          the overarching theme; the essential characters and details such as garb and environment;
          the moment in time to be depicted as well as the moments preceding and following it. It's up
          to me to figure out how all these pieces fit together visually.
        </p>
        <p class="text-p2 font-body text-text leading-relaxed">
          I work primarily in acrylic paint. I build the painting up slowly, working
          in gestural glazes before tightening up the essential details and areas of interest.
          Occasionally, I'll augment the piece with colored pencil or gouache airbrush.
        </p>
        <p class="text-p2 font-body text-text leading-relaxed">
          I take inspiration from the Golden Age illustrator N.C. Wyeth, as well as countless
          contemporary painters like Ray Bonilla and Jesper Ejsing. These painters' sense of light
          and shadow, direction of movement, and strong storytelling resonate with me.
        </p>
        <p class="text-p2 font-body text-text leading-relaxed">
          I'm currently fleshing out multiple science-fiction and fantasy worlds. Some are in
          collaboration with clients, and some are personal projects born from my own imagination. In
          all of them, I enjoy the balance of fleshing out impactful, action-oriented visuals with
          fine-tuned attention to worldbuilding detail.
        </p>
      </div>
    </div>
  {sorted.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 [grid-auto-rows:340px]">
      {sorted.map((piece) => (
        <PortfolioCard piece={piece} />
      ))}
    </div>
  ) : (
    <div class="py-24 text-center border border-dashed border-white/20 rounded">
      <p class="text-p1 font-body text-text/30">
        Portfolio pieces will appear here — add <code class="text-text-secondary">.md</code> files to{' '}
        <code class="text-text-secondary">src/content/portfolio/</code>.
      </p>
    </div>
  )}
</div>
