---
import logoRaw from '../assets/svg/logo.svg?raw';
import MobileMenu from './react/MobileMenu';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'ArcHive', href: '/books/archive' },
  { label: 'Portfolio', href: '/#portfolio' },
  { label: 'Books', href: '/#books' },
  { label: 'About', href: '/#about-me' },
];
---

<nav class="sticky top-0 z-50 bg-bg/30 backdrop-blur-md border-b border-white/10 relative">
  <div class="w-full mx-auto px-10 py-2 flex items-center justify-between">
    <a
      href="/"
      class="flex items-center gap-3 no-underline hover:no-underline hover:opacity-80 transition-opacity"
      aria-label="Aidan Holloway-Bidwell — home"
    >
      <span
        aria-hidden="true"
        class="block h-16 text-text [&>svg]:h-full [&>svg]:w-auto"
        set:html={logoRaw}
      />
      <div class="font-heading text-text uppercase leading-[0]">
        <span class="text-3xl font-bold tracking-widest">Aidan</span><br>
        <span class="text-[7.5pt] font-medium">Holloway&thinsp;-&thinsp;Bidwell</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-6 list-none m-0 p-0">
      <li>
        <a href="/" class="font-body text-p3 text-text tracking-wider hover:text-text-link transition-colors no-underline">
          Home
        </a>
      </li>
      <li>
        <a href="/books/archive" class="font-body text-p3 text-text tracking-wider hover:text-text-link transition-colors no-underline">
          ArcHive
        </a>
      </li>
      <li>
        <a href="/#portfolio" class="font-body text-p3 text-text tracking-wider hover:text-text-link transition-colors no-underline">
          Portfolio
        </a>
      </li>
      <li>
        <a href="/#books" class="font-body text-p3 text-text tracking-wider hover:text-text-link transition-colors no-underline">
          Books
        </a>
      </li>
      <li>
        <a href="/#about-me" class="font-body text-p3 text-text tracking-wider hover:text-text-link transition-colors no-underline">
          About
        </a>
      </li>
      <li>
        <a
          href="https://www.instagram.com/aidan_thats_me/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="text-text-link hover:text-text transition-colors flex items-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"></circle>
          </svg>
        </a>
      </li>
      <li>
        <a
          href="mailto:aidan@aidandraws.com"
          aria-label="Email"
          class="text-text-link hover:text-text transition-colors flex items-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <polyline points="2,4 12,13 22,4"></polyline>
          </svg>
        </a>
      </li>
    </ul>

    <!-- Mobile: hamburger + social icons -->
    <div class="flex md:hidden items-center gap-4">
      <MobileMenu links={navLinks} client:load />
      <a
        href="https://www.instagram.com/aidan_thats_me/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-text-link hover:text-text transition-colors flex items-center"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"></circle>
        </svg>
      </a>
      <a
        href="mailto:aidan@aidandraws.com"
        aria-label="Email"
        class="text-text-link hover:text-text transition-colors flex items-center"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <polyline points="2,4 12,13 22,4"></polyline>
        </svg>
      </a>
    </div>
  </div>
</nav>
