---
interface Props {
  purchaseUrl: string;
  price?: string;
  pitch?: string;
  numPages?: number;
  dimensions?: string;
  binding?: string;
  bindingStyle?: string;
  print?: string;
  stock?: string;
}

const { purchaseUrl, price, pitch, numPages, dimensions, binding, bindingStyle, print, stock } = Astro.props;

const specs = [
  dimensions && { label: 'Size', value: dimensions },
  print && { label: 'Print', value: print },
  binding && { label: 'Cover', value: binding },
  numPages && { label: 'Pages', value: `${numPages}` },
  stock && { label: 'Paper', value: stock },
  bindingStyle && { label: 'Binding', value: bindingStyle },
].filter(Boolean) as { label: string; value: string }[];
---

<div class="flex flex-col gap-6">
  {pitch && (
    <p class="font-body text-p2 text-text !mt-0 !mb-0 flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="size-4 text-text-title flex-none">
        <path fill-rule="evenodd" d="M9 4.5a.75.75 0 0 1 .721.544l.813 2.846a3.75 3.75 0 0 0 2.576 2.576l2.846.813a.75.75 0 0 1 0 1.442l-2.846.813a3.75 3.75 0 0 0-2.576 2.576l-.813 2.846a.75.75 0 0 1-1.442 0l-.813-2.846a3.75 3.75 0 0 0-2.576-2.576l-2.846-.813a.75.75 0 0 1 0-1.442l2.846-.813A3.75 3.75 0 0 0 7.466 7.89l.813-2.846A.75.75 0 0 1 9 4.5ZM18 1.5a.75.75 0 0 1 .728.568l.258 1.036c.236.94.97 1.674 1.91 1.91l1.036.258a.75.75 0 0 1 0 1.456l-1.036.258c-.94.236-1.674.97-1.91 1.91l-.258 1.036a.75.75 0 0 1-1.456 0l-.258-1.036a2.625 2.625 0 0 0-1.91-1.91l-1.036-.258a.75.75 0 0 1 0-1.456l1.036-.258a2.625 2.625 0 0 0 1.91-1.91l.258-1.036A.75.75 0 0 1 18 1.5ZM16.5 15a.75.75 0 0 1 .712.513l.394 1.183c.15.447.5.799.948.948l1.183.395a.75.75 0 0 1 0 1.422l-1.183.395c-.447.15-.799.5-.948.948l-.395 1.183a.75.75 0 0 1-1.422 0l-.395-1.183a1.5 1.5 0 0 0-.948-.948l-1.183-.395a.75.75 0 0 1 0-1.422l1.183-.395c.447-.15.799-.5.948-.948l.395-1.183A.75.75 0 0 1 16.5 15Z" clip-rule="evenodd" />
      </svg>
      {pitch}
    </p>
  )}
  <div class="flex flex-col sm:flex-row sm:items-end gap-6">
    <div class="flex-none flex flex-col items-start gap-2">
      {price && <p class="font-heading text-h4 text-text-title">{price}</p>}
      <a
        href={purchaseUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-text-link text-bg font-heading font-bold uppercase tracking-widest px-6 pb-2.5 pt-3.5 rounded-full no-underline hover:opacity-70 transition-opacity whitespace-nowrap"
      >
        Pre-order a signed copy
      </a>
    </div>
    <div class="flex-1 grid grid-cols-2 sm:grid-cols-3 gap-x-8 gap-y-3">
      {specs.map(({ label, value }) => (
        <div>
          <p class="font-heading uppercase tracking-wider text-p3 text-text-secondary !mb-0">{label}</p>
          <p class="font-body text-p2 text-text !mt-0">{value}</p>
        </div>
      ))}
    </div>
  </div>
</div>
