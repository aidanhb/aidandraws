---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  piece: CollectionEntry<'portfolio'>;
}

const { piece } = Astro.props;
---

<a
  href={`/${piece.slug}`}
  class="block h-full overflow-hidden group relative no-underline hover:no-underline"
  aria-label={piece.data.title}
>
  <Image
    src={piece.data.heroImage}
    alt={piece.data.alt}
    width={600}
    height={340}
    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
    style={piece.data.objectPosition ? `object-position: ${piece.data.objectPosition}` : undefined}
  />
  <div
    class="absolute inset-0 bg-gradient-to-t from-bg/90 via-bg/40 to-transparent transition-opacity duration-300 flex items-end p-4 opacity-0 group-hover:opacity-100"
  >
    <div>
      <p class="text-text-title font-heading text-sm uppercase tracking-wider">{piece.data.title}</p>
      {
        piece.data.tags.length > 0 && (
          <div class="flex gap-2 mt-1 flex-wrap">
            {piece.data.tags.map((tag) => (
              <span class="text-text-secondary text-xs">{tag}</span>
            ))}
          </div>
        )
      }
    </div>
  </div>
</a>
