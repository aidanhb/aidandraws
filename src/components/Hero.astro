---
import HeroCarousel from './react/HeroCarousel';
import { HERO_SIZES, type HeroSlide } from '../lib/hero-slides';

interface Props {
  slides: HeroSlide[];
}

const { slides } = Astro.props;
---

{
  slides.length > 0 ? (
    <HeroCarousel slides={slides} sizes={HERO_SIZES} client:load />
  ) : (
    <div class="w-full h-screen flex items-center justify-center">
      <p class="text-p1 font-body text-text/30 text-center px-6">
        Featured illustrations will appear here — add pieces with{' '}
        <code class="text-text-secondary">featured: true</code> to your portfolio collection.
      </p>
    </div>
  )
}
